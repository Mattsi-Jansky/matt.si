---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      tags.add(tag);
    }
  }
  return [...tags].map(tag => ({
    params: { tag: tag.replace(/\s+/g, '-').toLowerCase() },
    props: { tagName: tag },
  }));
}

const { tagName } = Astro.props;
const posts = (await getCollection('blog'))
  .filter(post => post.data.tags.includes(tagName))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: '2-digit',
  });
}
---

<BaseLayout title={`Posts tagged "${tagName}"`}>
  <div class="tag-archive">
    <header class="tag-archive-header">
      <a href="/tags/" class="tag-archive-back">All tags</a>
      <h1>{tagName}</h1>
      <p class="tag-archive-count">{posts.length} post{posts.length === 1 ? '' : 's'}</p>
    </header>
    <ul class="tag-archive-list">
      {posts.map(post => (
        <li>
          <a href={`/${post.slug}/`} class="tag-archive-link">
            <span class="tag-archive-title">{post.data.title}</span>
            <span class="tag-archive-date">{formatDate(post.data.date)}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

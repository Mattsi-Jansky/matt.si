---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import pathToTag from '../../shared/pathToTagGenerator';

const posts = await getCollection('blog');
const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}
const allTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags">
  <div class="tags-page">
    <h1>Tags</h1>
    <ul class="tags-page-list">
      {allTags.map(([tag, count]) => (
        <li>
          <a href={pathToTag(tag)}>
            <span class="tags-page-name">{tag}</span>
            <span class="tags-page-count">{count}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
